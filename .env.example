# ─── Database ────────────────────────────────────────────────────────────────
STORAGE_DATABASE_URL=postgresql://...

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=hello@getcorki.com

# ─── Apple Wallet ─────────────────────────────────────────────────────────────
# Find in Apple Developer Portal → Certificates, Identifiers & Profiles

# Your Apple Developer Team ID (10-char string, e.g. "ABC123DEFG")
APPLE_TEAM_ID=

# The Pass Type Identifier you registered (e.g. "pass.com.getcorki.wallet")
APPLE_PASS_TYPE_ID=

# The Pass Type ID signing certificate (.pem), base64-encoded
# openssl pkcs12 -in Certificates.p12 -clcerts -nokeys -out signerCert.pem
# cat signerCert.pem | base64 | tr -d '\n'
APPLE_PASS_CERT=

# The private key (.pem), base64-encoded
# openssl pkcs12 -in Certificates.p12 -nocerts -out signerKey.pem
# cat signerKey.pem | base64 | tr -d '\n'
APPLE_PASS_KEY=

# Passphrase protecting the private key (leave blank if none)
APPLE_PASS_KEY_PASSPHRASE=

# Apple WWDR G4 certificate, base64-encoded
# Download: https://www.apple.com/certificateauthority/ → "Apple Worldwide Developer Relations — G4"
# cat AppleWWDRCAG4.cer | base64 | tr -d '\n'
APPLE_WWDR_CERT=

# ─── Google Wallet ────────────────────────────────────────────────────────────
# Set up at: https://console.cloud.google.com → Google Wallet API

# Your Google Wallet Issuer ID (numeric, from Google Pay & Wallet Console)
GOOGLE_ISSUER_ID=

# The Generic Pass Class ID you created (e.g. "CorkiPromoPass")
GOOGLE_CLASS_ID=

# Service account email from your Google Cloud project
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# Service account JSON key file, base64-encoded
# cat service-account-key.json | base64 | tr -d '\n'
GOOGLE_SERVICE_ACCOUNT_KEY=

# ─── Promo ────────────────────────────────────────────────────────────────────
# The promo code to display on the pass (defaults to CORKIFRIEND if not set)
PROMO_CODE=CORKIFRIEND
